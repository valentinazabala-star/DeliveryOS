# ── Orbidi Production APIs ────────────────────────────────────────────────────
# Prod-line API key (tasks, task-full, etc.)
ORBIDI_API_KEY=""
ORBIDI_API_BASE="https://eu.api.orbidi.com/prod-line"

# Auth API key (accounts-with-brief)
ORBIDI_AUTH_API_KEY=""
ORBIDI_AUTH_API_BASE="https://eu.api.orbidi.com/auth/api"

# Django admin credentials for UUID scraping (sync-accounts endpoint)
ORBIDI_ADMIN_EMAIL=""
ORBIDI_ADMIN_PASSWORD=""
ORBIDI_ADMIN_URL="https://eu.api.orbidi.com/auth/admin/"

# ── App Auth ──────────────────────────────────────────────────────────────────
# Shared login password for all team members
OPSOS_APP_PASSWORD=""

# HMAC secret for session cookie signing (any long random string)
OPSOS_SESSION_SECRET=""

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Account UUID source ───────────────────────────────────────────────────────
# Defaults to data/orbidi-account-uuids.txt if not set
# ORBIDI_ACCOUNT_UUIDS_FILE="/ruta/a/uuids.txt"

# ── Business timezone (for "nuevos" date filter) ──────────────────────────────
OPSOS_BUSINESS_TZ="America/Bogota"

# ── Frontend (Vite build-time) ────────────────────────────────────────────────
# Orbidi console base for deep links (optional, defaults to EU prod)
# VITE_ORBIDI_PROD_LINE_BASE="https://eu.api.orbidi.com/prod-line"
# VITE_ORBIDI_CONSOLE_ORIGIN="https://eu.api.orbidi.com"
